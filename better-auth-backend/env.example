# HTTP port for the NestJS API (defaults to 3000 if unset; use 3001 if Next.js runs on 3000)
PORT=3001

# Browser origin of the Next.js app (CORS + Better Auth trustedOrigins)
FRONTEND_URL=http://localhost:3000

# Database backend: postgres (default) | mongodb | mysql
DATABASE=postgres

# PostgreSQL connection string — required when DATABASE=postgres (Prisma + app)
POSTGRES_URL=

# MongoDB connection string — required when DATABASE=mongodb
MONGODB_URI=
# Optional explicit database name when DATABASE=mongodb
MONGODB_DB_NAME=

# MySQL connection details — required when DATABASE=mysql
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306

BETTER_AUTH_URL=http://localhost:3001

# Better Auth signing secret — use a long random string in production
BETTER_AUTH_SECRET=

# Google OAuth client (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=



OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIMENSIONS=768
CHATBOT_VECTOR_INDEX=standup_chunks_vector_index