# HTTP port for the NestJS API (defaults to 3000 if unset; use 3001 if Next.js runs on 3000)
PORT=3001

# Browser origin of the Next.js app (CORS + Better Auth trustedOrigins)
FRONTEND_URL=http://localhost:3000

# Database backend: postgres (default) | mongodb | mysql
DATABASE=postgres

# PostgreSQL connection string — required when DATABASE=postgres (Prisma + app)
POSTGRES_URL=

# MongoDB connection string — required when DATABASE=mongodb
MONGODB_URI=
# Optional explicit database name when DATABASE=mongodb
MONGODB_DB_NAME=

# MySQL connection details — required when DATABASE=mysql
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306

BETTER_AUTH_URL=http://localhost:3001

# Better Auth signing secret — use a long random string in production
BETTER_AUTH_SECRET=

# Google OAuth client (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=



# Required when using the MongoDB vector chatbot (Transformers.js / ONNX in-process). Model weights download on first use.
CHATBOT_EMBED_MODEL=Xenova/all-mpnet-base-v2
# Required; must match model output size and Atlas vector index numDimensions.
CHATBOT_EMBEDDING_DIMENSIONS=768
# MongoDB Atlas Vector Search index name on standup_chunks.embedding
MONGODB_VECTOR_INDEX=standup_chunks_vector_index