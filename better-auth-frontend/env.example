# Public app origin used by Better Auth client in the browser.
# In production this should be your Vercel app URL (no trailing slash).
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:3000

# Public app origin used by API client calls in the browser.
# In production this should be your Vercel app URL (no trailing slash).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Private backend origin used by Next.js rewrites.
# In production set this to your Render backend URL (no trailing slash).
BACKEND_URL=http://localhost:3001
